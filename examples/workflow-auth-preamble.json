{
  "_doc": "Reusable login + CSRF capture preamble. Designed to be `include`d by other workflows so you don't repeat this boilerplate. After this runs, the parent workflow has {{csrf}} available and a logged-in session.",

  "steps": [
    {
      "name": "do_login",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/login",
        "headers": {"Content-Type": "application/x-www-form-urlencoded"},
        "body": "username={{user}}&password={{pass}}"
      }
    },
    {
      "name": "grab_csrf",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/my-account"
      },
      "extract": {
        "csrf": {"regex": "name=\"csrf\" value=\"([^\"]+)\""}
      }
    }
  ]
}
